%% 图3-4 评估数据存储ER图
%% Figure 3-4 Assessment Data Storage ER Diagram

erDiagram
    assessment_jobs ||--|{ assessment_dimensions : "1 次评估包含 6 条维度"
    assessment_jobs ||--o| assessment_summary : "1 条画像汇总"
    assessment_jobs ||--o{ assessment_report_blocks : "9-10 条报告块"
    candidates ||--o{ assessment_jobs : "1 个候选人多次评估"

    candidates {
        bigint id PK
        varchar name
        varchar current_title
        varchar target_role
        json    resume_raw
        text    supplement
        json    bigfive
        json    riasec
        json    quiz_abilities
    }

    assessment_jobs {
        varchar assessment_id PK "12 字符十六进制"
        bigint  user_id FK
        json    input_snapshot "候选人快照"
        varchar status "running/done/partial"
        json    data_flags
        timestamp created_at
    }

    assessment_dimensions {
        bigint  id PK
        varchar assessment_id FK
        varchar dimension "skills/knowledge/abilities/work_styles/interests/work_values"
        float   overall_score "1-7 分"
        varchar confidence "高/中/低"
        text    dimension_summary
        json    sub_dimensions "子维度评分数组"
        json    highlights "亮点子维度"
        json    focus_areas "关注子维度"
        varchar status "done/locked/partial"
    }

    assessment_summary {
        bigint  id PK
        varchar assessment_id FK
        varchar persona_label "4-6 字画像标签"
        text    narrative_intro "3-5 句叙事摘要"
        json    keywords "5-6 个能力关键词"
        json    top3_strengths "核心优势"
        json    top3_improvements "提升方向"
    }

    assessment_report_blocks {
        int     id PK
        varchar assessment_id FK
        varchar block_id "score_table/narrative_summary/strength_top3/.../dimension_skills"
        longtext block_json "面向用户的展示数据"
        datetime generated_at
    }
