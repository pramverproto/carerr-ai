%% 图5-12 简历解析流程图
%% Figure 5-12 Resume Parsing Flowchart

flowchart TD
    Start(["用户上传 Word 简历"])
    Up["前端 → POST /resume/upload<br/>(multipart/form-data)"]
    Save["保存原文件 →<br/>resume_uploads.raw_text"]
    Doc["python-docx<br/>提取纯文本"]

    Prompt["构造解析 Prompt<br/>(System: 角色 + JSON Schema 约束)<br/>(User: 简历纯文本)"]

    LLM{"LLM 智能解析<br/>(GPT-4o, JSON Mode)"}

    Json["返回结构化 JSON<br/>{name, age, education[],<br/>experience[], skills[],<br/>certifications[], ...}"]

    Validate{"Schema 校验<br/>+ 字段完整度评估"}

    LowConf["置信度低字段<br/>→ 标记 highlight_field=true"]
    Pass["全部字段合规"]

    Validate -->|部分字段缺失/异常| LowConf
    Validate -->|通过| Pass

    Save2[("写入 candidates.resume_raw<br/>(JSON 字段)<br/>关联 user_id")]

    UI["前端展示解析结果<br/>(高亮提示低置信度字段)"]
    Edit{"用户是否<br/>需要修改?"}
    Update["用户编辑 →<br/>PUT /candidate/profile"]
    Done(["解析完成<br/>可触发能力评估"])

    Start --> Up --> Save --> Doc --> Prompt --> LLM --> Json --> Validate
    LowConf --> Save2
    Pass --> Save2
    Save2 --> UI --> Edit
    Edit -->|是| Update --> Save2
    Edit -->|否| Done

    classDef startend fill:#e8eaf6,stroke:#3949ab,stroke-width:2px
    classDef io fill:#e3f2fd,stroke:#1976d2,stroke-width:1.5px
    classDef llm fill:#fff3e0,stroke:#f57c00,stroke-width:1.5px
    classDef val fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px
    classDef db fill:#f1f8e9,stroke:#558b2f,stroke-width:2px

    class Start,Done startend
    class Up,Save,Doc,UI,Update io
    class Prompt,LLM,Json llm
    class Validate,LowConf,Pass,Edit val
    class Save2 db
