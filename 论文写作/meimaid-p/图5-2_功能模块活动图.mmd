%% 图5-2 功能模块活动图
%% Figure 5-2 Functional Module Activity Diagram

flowchart TD
    Start(["开始"])
    Login["用户注册 / 登录"]
    Upload["上传简历 (Word)"]
    Parse["LLM 简历解析<br/>→ 候选人结构化 JSON"]
    Sup["填写自述补充<br/>(可选导入 IPIP / RIASEC)"]

    Trigger["触发能力评估"]
    Eval["1+6+1 多 Agent 并行评估<br/>(asyncio.gather)"]
    Report["6 个维度报告 Agent<br/>生成可视化报告块"]
    View["查看雷达图与维度详情"]

    Decision1{"用户是否<br/>触发路线推荐?"}

    Recall["双路 JD 召回<br/>语义向量 + 技能关键词"]
    Design["LLM 三阶段路线设计"]
    Show["展示 3-4 条候选路线"]
    Select["用户选定目标路线"]
    Save["save-path<br/>写入 career_path_progress"]

    Plan["五模块规划生成<br/>match_overview / jd_recommendations<br/>gap_analysis / action_plan / future_outlook"]
    Confirm["用户确认行动计划"]
    Week["生成周计划 (plan_weeks)"]
    Day["拆解每日任务 (plan_daily_tasks)"]

    Track["每日签到 + 反思笔记"]
    Decision2{"是否完成<br/>当前阶段?"}
    StageNext["stage-complete<br/>推进至下一阶段"]
    End(["结束 / 持续追踪"])

    Start --> Login --> Upload --> Parse --> Sup --> Trigger --> Eval --> Report --> View
    View --> Decision1
    Decision1 -->|是| Recall --> Design --> Show --> Select --> Save --> Plan --> Confirm --> Week --> Day --> Track
    Decision1 -->|否| End
    Track --> Decision2
    Decision2 -->|否| Track
    Decision2 -->|是| StageNext --> Plan

    classDef startend fill:#e8eaf6,stroke:#3949ab,stroke-width:2px
    classDef act fill:#e3f2fd,stroke:#1976d2,stroke-width:1.5px
    classDef llm fill:#fff3e0,stroke:#f57c00,stroke-width:1.5px
    classDef dec fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px
    classDef plan fill:#f1f8e9,stroke:#558b2f,stroke-width:1.5px

    class Start,End startend
    class Login,Upload,Sup,View,Show,Select,Save,Confirm,Track,StageNext act
    class Parse,Eval,Report,Recall,Design,Plan,Week,Day llm
    class Decision1,Decision2 dec
    class Trigger plan
