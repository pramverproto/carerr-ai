%% 图5-4 功能模块图
%% Figure 5-4 Functional Module Diagram

flowchart TB
    Sys["智能职业发展辅助系统"]

    Sys --> App["应用模块"]
    Sys --> Mgr["管理模块"]

    subgraph AppMods["应用模块 (面向用户的核心业务)"]
        direction TB
        App --> M1["用户信息管理<br/>与简历解析"]
        M1 --> M1a["注册 / 登录"]
        M1 --> M1b["简历上传与解析"]
        M1 --> M1c["个人档案编辑"]
        M1 --> M1d["自述补充与测评导入"]

        App --> M2["能力评估<br/>与报告生成"]
        M2 --> M2a["1+6+1 多 Agent 调度"]
        M2 --> M2b["双模式评估 (done/locked)"]
        M2 --> M2c["6 维度报告 Agent 渲染"]
        M2 --> M2d["雷达图 / 维度详情展示"]

        App --> M3["职业路线推荐<br/>与规划"]
        M3 --> M3a["双路 JD 召回"]
        M3 --> M3b["LLM 三阶段路线设计"]
        M3 --> M3c["路线选择 (save-path)"]
        M3 --> M3d["5 个 Block 规划生成"]
        M3 --> M3e["周计划 / 日任务拆解"]
        M3 --> M3f["阶段推进 (stage-complete)"]

        App --> M4["AI 对话"]
        M4 --> M4a["SSE 流式输出"]
        M4 --> M4b["ReAct 工具调用循环"]
        M4 --> M4c["多轮上下文记忆"]
    end

    subgraph MgrMods["管理模块 (横切关注点)"]
        direction TB
        Mgr --> M5["用户认证管理"]
        M5 --> M5a["JWT 无状态认证"]
        M5 --> M5b["bcrypt 密码哈希"]

        Mgr --> M6["成长档案管理"]
        M6 --> M6a["历次评估归档"]
        M6 --> M6b["规划里程碑记录"]
        M6 --> M6c["纵向对比与回溯"]
    end

    classDef root fill:#fce4ec,stroke:#c2185b,stroke-width:2.5px
    classDef cat fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    classDef mod fill:#fff3e0,stroke:#f57c00,stroke-width:1.5px
    classDef leaf fill:#f1f8e9,stroke:#558b2f,stroke-width:1.2px

    class Sys root
    class App,Mgr cat
    class M1,M2,M3,M4,M5,M6 mod
    class M1a,M1b,M1c,M1d,M2a,M2b,M2c,M2d,M3a,M3b,M3c,M3d,M3e,M3f,M4a,M4b,M4c,M5a,M5b,M6a,M6b,M6c leaf
