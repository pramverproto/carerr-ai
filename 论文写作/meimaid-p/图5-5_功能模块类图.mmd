%% 图5-5 功能模块类图
%% Figure 5-5 Functional Module Class Diagram

classDiagram
    class UserAccount {
        +Long id
        +String username
        +String passwordHash
        +String email
        +register() User
        +authenticate(pwd) JWT
    }

    class CandidateProfile {
        +Long id
        +String name
        +Integer age
        +String currentTitle
        +String targetRole
        +Json resumeRaw
        +String supplement
        +Json bigfive
        +Json riasec
        +Json quizAbilities
        +parseResume(file) Json
        +updateProfile(payload) void
    }

    class AssessmentEngine {
        +String assessmentId
        +runInputParser() CandidateJson
        +runDimensionAgents() List~DimensionScore~
        +runSummaryAgent() Summary
        -asyncioGather(agents)
    }

    class DimensionAgent {
        <<abstract>>
        +String dimension
        +String mode
        +run(candidate) DimensionScore
    }

    class SkillsAgent
    class KnowledgeAgent
    class AbilitiesAgent
    class WorkStylesAgent
    class InterestsAgent
    class WorkValuesAgent

    class ReportEngine {
        +renderRadarBlock() Block
        +renderDimensionBlock(dim) Block
        +renderStrengthTop3() Block
        +cacheBlocks() void
    }

    class CareerPathRecommender {
        +recallSemantic(profile) List~JD~
        +recallBySkills(profile) List~JD~
        +mergeAndDedupe() List~JD~
        +llmGeneratePaths() List~Path~
    }

    class PathProgressManager {
        +String pathCode
        +Integer currentStage
        +savePath(pathJson) void
        +stageComplete(note) Stage
    }

    class PlanGenerator {
        +buildMatchOverview() Block
        +buildJDRecommendations() Block
        +buildGapAnalysis() Block
        +buildActionPlan() Block
        +buildFutureOutlook() Block
    }

    class ScheduleManager {
        +generateWeeklyPlan() PlanWeek
        +generateDailyTasks() List~DailyTask~
        +markComplete(taskIds) void
        +addReflection(note) void
    }

    class ChatAgent {
        +String sessionId
        +reactLoop() Stream
        +callTool(name, args) Result
        +retrieveContext() void
    }

    UserAccount "1" -- "1" CandidateProfile : owns
    CandidateProfile "1" -- "*" AssessmentEngine : triggers
    AssessmentEngine "1" -- "6" DimensionAgent : orchestrates
    DimensionAgent <|-- SkillsAgent
    DimensionAgent <|-- KnowledgeAgent
    DimensionAgent <|-- AbilitiesAgent
    DimensionAgent <|-- WorkStylesAgent
    DimensionAgent <|-- InterestsAgent
    DimensionAgent <|-- WorkValuesAgent
    AssessmentEngine "1" -- "1" ReportEngine : feeds
    AssessmentEngine "1" -- "*" CareerPathRecommender : provides_profile
    CareerPathRecommender "1" -- "*" PathProgressManager : selected
    PathProgressManager "1" -- "*" PlanGenerator : drives
    PlanGenerator "1" -- "*" ScheduleManager : decomposes
    UserAccount "1" -- "*" ChatAgent : converses
