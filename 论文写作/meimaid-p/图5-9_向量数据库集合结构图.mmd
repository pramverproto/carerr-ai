flowchart TB
    Qdrant[("Qdrant 1.17<br/>HNSW 索引 + 余弦相似度<br/>1536 维向量")]

    subgraph Col1["onet_occupations 集合"]
        direction TB
        O_Vec["vector: float[1536]<br/>(职业描述文本嵌入)"]
        subgraph O_Pay["payload (元数据)"]
            O1["onetsoc_code: char(10)"]
            O2["title: 职业名称"]
            O3["description: 职业描述"]
            O4["job_zone: 1-5"]
            O5["riasec_R/I/A/S/E/C: float"]
            O6["dim_skills / knowledge /<br/>abilities / work_styles /<br/>work_values: float (1-7)"]
            O7["sub-dimension scores<br/>(skill_basic / knowledge_tech /...)"]
            O8["tech_tools_json /<br/>core_tasks_json /<br/>related_occ_json"]
        end
        O_Vec -.附加.-> O_Pay
    end

    subgraph Col2["jobs 集合"]
        direction TB
        J_Vec["vector: float[1536]<br/>(JD 全文文本嵌入)"]
        subgraph J_Pay["payload (元数据)"]
            J1["jd_id: 全局唯一标识"]
            J2["title: 岗位标题"]
            J3["company: 企业名称"]
            J4["jd_text: JD 全文"]
            J5["salary_range: 薪资范围"]
            J6["skills_tags: 技能标签数组"]
            J7["onetsoc_code: 关联 O*NET 编码"]
            J8["location / industry /<br/>job_zone / posted_at"]
        end
        J_Vec -.附加.-> J_Pay
    end

    Qdrant --> Col1
    Qdrant --> Col2

    Use1["规划阶段使用<br/>规则评分 (与 O*NET 标准对齐)<br/>未来阶段展望"]
    Use2["路线推荐阶段使用<br/>双路 JD 召回<br/>(语义向量 + 技能关键词)"]

    Col1 --> Use1
    Col2 --> Use2

    Emb["text-embedding-3-small<br/>(OpenAI 第三代嵌入模型)"]
    Emb -.写入.-> Col1
    Emb -.写入.-> Col2

